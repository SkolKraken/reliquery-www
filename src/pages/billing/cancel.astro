---
import Base from "../../layouts/Base.astro";
---
<Base title="Checkout Canceled — Reliquery" description="Your checkout was canceled. No charges were made.">
  <article class="mx-auto max-w-xl px-6 py-24 text-center">
    <h1 class="text-3xl font-bold text-ink">Checkout canceled</h1>
    <p class="mt-4 text-ink/70 leading-relaxed">
      No charges were made. You can close this tab and continue using Reliquery on the Free plan.
    </p>
    <p class="mt-6 text-ink/50 text-sm">
      Changed your mind? You can upgrade anytime from the Admin & Usage panel in the extension.
    </p>
    <div class="mt-10 flex flex-col gap-3 items-center">
      <a href="/" class="text-primary font-semibold text-sm hover:underline">Back to reliquery.app</a>
      <a href="mailto:support@reliquery.app" class="text-ink/40 text-xs hover:underline">Questions? support@reliquery.app</a>
    </div>
  </article>
</Base>
