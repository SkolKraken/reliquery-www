---
import Base from "../../layouts/Base.astro";
---
<Base title="Welcome to Pro — Reliquery" description="Your Reliquery Pro subscription is active.">
  <article class="mx-auto max-w-xl px-6 py-24 text-center">
    <p class="text-5xl mb-6">🔮</p>
    <h1 class="text-3xl font-bold text-ink">Welcome to Pro</h1>
    <p class="mt-4 text-ink/70 leading-relaxed">
      Your subscription is active. You now have 100 analyses per month across Audit and Scout.
    </p>
    <p class="mt-6 text-ink/50 text-sm">
      You can close this tab and return to the Reliquery side panel. Your Pro status will appear automatically.
    </p>
    <div class="mt-10 flex flex-col gap-3 items-center">
      <a href="/" class="text-primary font-semibold text-sm hover:underline">Back to reliquery.app</a>
      <a href="mailto:support@reliquery.app" class="text-ink/40 text-xs hover:underline">Questions? support@reliquery.app</a>
    </div>
  </article>
</Base>
