---
/**
 * Referral landing page.
 *
 * URL form: reliquery.app/r?ref=CODE
 *
 * No PII collected — just shows the visitor their friend's code prominently
 * with a copy button. After install, the visitor pastes the code in the
 * extension (onboarding step) to attribute the referral. This avoids the
 * "did I use the same email?" failure mode of email-based attribution.
 *
 * Static page — code is read client-side from the query string. If the
 * code is invalid the page still renders (visitor can install anyway,
 * just no attribution).
 */

import Base from "../layouts/Base.astro";

const CWS_URL = "https://chromewebstore.google.com/detail/reliquery/kgkpejegjlfcmghgkcebfekdnocgohbi";
---
<Base
  title="A friend invited you to Reliquery"
  description="Brand intelligence for any web page — Audit, Scout competitors, and Forge changes from a Chrome side panel."
>
  <article class="mx-auto max-w-2xl px-6 py-16 text-center">
    <p class="inline-block rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-100 text-xs font-semibold uppercase tracking-wider px-3 py-1">
      You've been invited
    </p>

    <h1 class="mt-6 text-3xl sm:text-4xl font-bold tracking-tight text-ink dark:text-ink-dark leading-tight">
      If you're seeing this page, you have a friend who really wants you to succeed.
    </h1>

    <p class="mt-6 text-lg text-ink/70 dark:text-ink-dark/70 leading-relaxed">
      They've been using <strong>Reliquery</strong> — a Chrome extension that scores any web page
      against your brand documents, shows you how competitors position against you, and lets you
      vibe-code design changes live.
    </p>

    <!-- Step 1: Install -->
    <div class="mt-12">
      <p class="text-xs font-bold text-ink/50 dark:text-ink-dark/50 uppercase tracking-widest">Step 1</p>
      <h2 class="mt-2 text-xl font-bold text-ink dark:text-ink-dark">Install Reliquery</h2>
      <a
        id="install-cta"
        href={CWS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block rounded-lg bg-primary px-7 py-4 text-white font-semibold text-base hover:opacity-90 transition shadow-lg shadow-primary/20"
      >
        Add to Chrome — Free
      </a>
      <p class="mt-3 text-xs text-ink/50 dark:text-ink-dark/50">
        Free to install · No credit card · Pro plan when you're ready
      </p>
    </div>

    <!-- Step 2: Claim the code -->
    <div class="mt-12 mx-auto max-w-md rounded-2xl border-2 border-primary/30 dark:border-primary/40 bg-white dark:bg-surface-dark p-7 shadow-lg shadow-primary/5">
      <p class="text-xs font-bold text-ink/50 dark:text-ink-dark/50 uppercase tracking-widest">Step 2</p>
      <h2 class="mt-2 text-xl font-bold text-ink dark:text-ink-dark">Lock in your bonus</h2>
      <p class="mt-2 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
        After installing, paste this code into the Reliquery extension when it asks
        for a referral code. We'll credit you and your friend automatically when you upgrade to Pro.
      </p>

      <!-- The code, big and copy-able -->
      <div class="mt-5 flex items-center justify-center gap-2">
        <code
          id="ref-code"
          class="text-2xl font-mono font-bold tracking-[0.2em] bg-paper dark:bg-paper-dark border border-black/10 dark:border-white/15 rounded-lg px-5 py-3 text-primary dark:text-primary-100 select-all"
        >
          ········
        </code>
        <button
          id="copy-btn"
          type="button"
          class="rounded-lg bg-accent px-4 py-3 text-white font-semibold text-sm hover:opacity-90 transition whitespace-nowrap"
        >
          Copy
        </button>
      </div>
      <p id="copy-status" class="mt-3 text-xs text-ink/60 dark:text-ink-dark/60 min-h-[1em]"></p>

      <ul class="mt-5 space-y-1.5 text-sm text-ink/80 dark:text-ink-dark/80 text-left">
        <li class="flex items-start gap-2">
          <span class="text-accent font-bold mt-0.5">✦</span>
          <span>You both get <strong>+25 bonus analyses</strong></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent font-bold mt-0.5">✦</span>
          <span>You both get <strong>25% off your next Pro invoice</strong></span>
        </li>
      </ul>

      <p class="mt-4 text-[11px] text-ink/50 dark:text-ink-dark/50 leading-relaxed">
        Bonuses activate after your second successful Pro invoice — protects everyone from
        refund fraud. Code expires in 90 days.
      </p>
    </div>

    <!-- How it works -->
    <div class="mt-16 grid sm:grid-cols-3 gap-4 text-left">
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold text-primary dark:text-primary-100">Audit</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          Score your pages against your own brand documents. Every drift finding cites the exact passage it violates.
        </p>
      </div>
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold text-accent">Scout</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          See how competitors position against you — category, voice, pricing — side by side.
        </p>
      </div>
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Forge</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          Type a design change in plain English. Reliquery applies the CSS live to the page.
        </p>
      </div>
    </div>

    <p class="mt-12 text-xs text-ink/50 dark:text-ink-dark/50">
      <a href="/" class="hover:underline">Learn more about Reliquery</a> ·
      <a href="/onboarding" class="hover:underline">Setup guide</a> ·
      <a href="/privacy" class="hover:underline">Privacy</a>
    </p>
  </article>

  <script define:vars={{ CWS_URL }}>
    // Read the referral code from the query string and decorate the page.
    const params = new URLSearchParams(window.location.search);
    const code = (params.get('ref') || '').trim().toUpperCase();

    // Show the code in the prominent box (or hide the box if no code).
    const codeEl = document.getElementById('ref-code');
    const copyBtn = document.getElementById('copy-btn');
    const copyStatus = document.getElementById('copy-status');

    if (code && /^[A-Z0-9]{4,16}$/.test(code)) {
      if (codeEl) codeEl.textContent = code;
    } else {
      // No code in URL — hide the entire claim section, page still
      // serves as a generic install link.
      const claimSection = codeEl?.closest('.mt-12.mx-auto');
      if (claimSection) claimSection.style.display = 'none';
    }

    // Add UTM params to the install CTA so attribution shows up in
    // analytics even though the actual referral attribution happens
    // post-install via the code paste flow.
    const ctaLink = document.getElementById('install-cta');
    if (ctaLink && code) {
      const utmUrl = new URL(CWS_URL);
      utmUrl.searchParams.set('utm_source', 'referral');
      utmUrl.searchParams.set('utm_medium', 'lp');
      utmUrl.searchParams.set('utm_campaign', code);
      ctaLink.href = utmUrl.toString();
    }

    // Copy-to-clipboard with visible feedback.
    if (copyBtn && code) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code);
          copyStatus.textContent = '✓ Copied. Paste it in the extension after installing.';
          copyBtn.textContent = '✓ Copied';
          setTimeout(() => {
            copyBtn.textContent = 'Copy';
          }, 2500);
        } catch {
          copyStatus.textContent = "Couldn't copy automatically — select the code and copy manually.";
        }
      });
    }
  </script>
</Base>
