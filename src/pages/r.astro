---
/**
 * Referral landing page.
 *
 * URL form: reliquery.app/r?ref=CODE
 *
 * We use a query string instead of a path param (/r/CODE) so this page
 * can be statically generated by Cloudflare Pages — no SSR needed. The
 * code is read client-side and posted to /api/referral/intent if the
 * visitor submits their email. If the code is invalid, the backend
 * silently drops the intent and the visitor still gets to install.
 *
 * Pretty URLs (/r/CODE) would require switching the site to hybrid SSR.
 * Worth doing later if /r becomes a meaningful share surface.
 */

import Base from "../layouts/Base.astro";

const CWS_URL = "https://chromewebstore.google.com/detail/reliquery/kgkpejegjlfcmghgkcebfekdnocgohbi";
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "https://backend-blue-iota-40.vercel.app";
---
<Base
  title="A friend invited you to Reliquery"
  description="Brand intelligence for any web page — Audit, Scout competitors, and Forge changes from a Chrome side panel."
>
  <article class="mx-auto max-w-2xl px-6 py-16 text-center">
    <p class="inline-block rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-100 text-xs font-semibold uppercase tracking-wider px-3 py-1">
      You've been invited
    </p>

    <h1 class="mt-6 text-3xl sm:text-4xl font-bold tracking-tight text-ink dark:text-ink-dark leading-tight">
      If you're seeing this page, you have a friend who really wants you to succeed.
    </h1>

    <p class="mt-6 text-lg text-ink/70 dark:text-ink-dark/70 leading-relaxed">
      They've been using <strong>Reliquery</strong> — a Chrome extension that scores any web page
      against your brand documents, shows you how competitors position against you, and lets you
      vibe-code design changes live.
    </p>

    <a
      id="install-cta"
      href={CWS_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10 inline-block rounded-lg bg-primary px-7 py-4 text-white font-semibold text-base hover:opacity-90 transition shadow-lg shadow-primary/20"
    >
      Add to Chrome — Free
    </a>

    <p class="mt-3 text-xs text-ink/50 dark:text-ink-dark/50">
      Free to install · No credit card · Pro plan when you're ready
    </p>

    <!-- Email capture (the attribution mechanism) -->
    <div class="mt-12 mx-auto max-w-md rounded-2xl border border-black/10 dark:border-white/10 bg-white dark:bg-surface-dark p-6">
      <p class="text-sm font-bold text-ink dark:text-ink-dark">
        Want a reminder + your bonus locked in?
      </p>
      <p class="mt-2 text-sm text-ink/60 dark:text-ink-dark/60 leading-relaxed">
        Drop your email — we'll know to credit your friend when you upgrade to Pro.
      </p>
      <form id="intent-form" class="mt-4 flex flex-col sm:flex-row gap-2">
        <input
          id="intent-email"
          type="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          class="flex-1 rounded-lg border border-black/10 dark:border-white/20 bg-paper dark:bg-paper-dark px-4 py-2.5 text-sm text-ink dark:text-ink-dark focus:outline-none focus:ring-2 focus:ring-primary/40"
        />
        <button
          type="submit"
          class="rounded-lg bg-accent px-5 py-2.5 text-white font-semibold text-sm hover:opacity-90 transition whitespace-nowrap"
        >
          Save my spot
        </button>
      </form>
      <p id="intent-status" class="mt-3 text-xs text-ink/60 dark:text-ink-dark/60 min-h-[1em]"></p>
    </div>

    <!-- How it works -->
    <div class="mt-16 grid sm:grid-cols-3 gap-4 text-left">
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold text-primary dark:text-primary-100">Audit</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          Score your pages against your own brand documents. Every drift finding cites the exact passage it violates.
        </p>
      </div>
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold text-accent">Scout</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          See how competitors position against you — category, voice, pricing — side by side.
        </p>
      </div>
      <div class="rounded-xl border border-black/5 dark:border-white/10 bg-white dark:bg-surface-dark p-5">
        <p class="text-sm font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Forge</p>
        <p class="mt-1 text-sm text-ink/70 dark:text-ink-dark/70 leading-relaxed">
          Type a design change in plain English. Reliquery applies the CSS live to the page.
        </p>
      </div>
    </div>

    <p class="mt-12 text-xs text-ink/50 dark:text-ink-dark/50">
      <a href="/" class="hover:underline">Learn more about Reliquery</a> ·
      <a href="/onboarding" class="hover:underline">Setup guide</a> ·
      <a href="/privacy" class="hover:underline">Privacy</a>
    </p>
  </article>

  <script define:vars={{ apiBase, CWS_URL }}>
    // Read the referral code from the query string and decorate the install
    // CTA + intent form with it.
    const params = new URLSearchParams(window.location.search);
    const code = (params.get('ref') || '').trim();

    // Add UTM params to the install CTA so attribution shows up in analytics
    // even for visitors who don't submit the email form.
    const ctaLink = document.getElementById('install-cta');
    if (ctaLink && code) {
      const utmUrl = new URL(CWS_URL);
      utmUrl.searchParams.set('utm_source', 'referral');
      utmUrl.searchParams.set('utm_medium', 'lp');
      utmUrl.searchParams.set('utm_campaign', code);
      ctaLink.href = utmUrl.toString();
    }

    // Intent form → POST /api/referral/intent
    const form = document.getElementById('intent-form');
    const status = document.getElementById('intent-status');
    const input = document.getElementById('intent-email');

    if (form && status && input) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!code) {
          status.textContent = 'Missing referral code in this URL — install via the button above.';
          return;
        }
        const email = input.value.trim();
        if (!email || !email.includes('@')) {
          status.textContent = 'Please enter a valid email address.';
          return;
        }
        status.textContent = 'Saving…';
        try {
          const resp = await fetch(`${apiBase}/api/referral/intent`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, email }),
          });
          if (resp.ok) {
            status.textContent = "✓ Got it. Click 'Add to Chrome' above to install.";
            input.disabled = true;
          } else {
            status.textContent = "Couldn't save right now — go ahead and install, we'll catch up.";
          }
        } catch (err) {
          status.textContent = "Couldn't save right now — go ahead and install, we'll catch up.";
        }
      });
    }
  </script>
</Base>
